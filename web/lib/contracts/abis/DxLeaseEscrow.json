      "stateMutability": "view"
    },
    {
      "type": "event",
      "name": "AuctionOpened",
      "inputs": [
        { "name": "listingId", "type": "uint256", "indexed": true },
        { "name": "seller", "type": "address", "indexed": true },
        { "name": "dxToken", "type": "address", "indexed": true },
        { "name": "xStock", "type": "address", "indexed": false },
        { "name": "amount", "type": "uint256", "indexed": false },
        { "name": "basePrice", "type": "uint256", "indexed": false },
        { "name": "auctionEnd", "type": "uint256", "indexed": false },
        { "name": "leaseDuration", "type": "uint256", "indexed": false }
      ]
    },
    {
